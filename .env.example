# ── LLM (OpenAI) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model selection (overridable)
MODEL_CHEAP=gpt-4o-mini
MODEL_SMART=gpt-4o

# ── Data sources ─────────────────────────────────────────────
# Finnhub (company news + earnings calendar). Free tier: https://finnhub.io
FINNHUB_API_KEY=
# FRED (macro). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# SEC EDGAR requires a descriptive User-Agent (no key). Use your contact.
SEC_USER_AGENT=MarketJournal research yourname@example.com

# ── Runtime behaviour ────────────────────────────────────────
# When true, agents are skipped and deterministic stub reasoning is used (no LLM cost).
MARKET_JOURNAL_OFFLINE=false
# When true, network data clients return cached/empty data instead of calling APIs.
MARKET_JOURNAL_USE_CACHE_ONLY=false
